# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/game
MONGODB_DB_NAME=game

# Better Auth
BETTER_AUTH_SECRET=your-secure-random-secret-at-least-32-chars
# Base URL of the backend API, used to build Better Auth callback URLs
BETTER_AUTH_URL=http://localhost:3000

# Frontend origin used for OAuth callback redirects and trusted-origin checks
REQUEST_ORIGIN=http://localhost:5173

# CORS - allowed origin for API requests (usually same as REQUEST_ORIGIN)
CORS_ORIGIN=http://localhost:5173

# Cookie sameSite: 'lax' (default, same-site), 'none' (cross-domain, requires HTTPS)
COOKIE_SAME_SITE=lax

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Register this Better Auth callback URL with Google:
# http://localhost:3000/api/auth/callback/google

# Apple OAuth
APPLE_CLIENT_ID=com.example.myapp.signin
APPLE_TEAM_ID=K7H9M2P4Q1R
APPLE_KEY_ID=W3X5Y8Z2A6B
# Apple private key: full PEM string (with -----BEGIN/END-----) or raw key content.
# Full PEM: APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQgREPLACE_WITH_YOUR_APPLE_PRIVATE_KEY\n-----END PRIVATE KEY-----"
# Register this Better Auth callback URL with Apple:
# http://localhost:3000/api/auth/callback/apple
