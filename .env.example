# Server
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/game
MONGODB_DB_NAME=game

# Session (required for cookie-based auth)
SESSION_SECRET=your-secure-random-secret-at-least-32-chars

# Frontend URL - where to redirect after OAuth (dev: http://localhost:5173, prod: https://yourdomain.com)
REQUEST_ORIGIN=http://localhost:5173

# CORS - allowed origin for API requests (usually same as REQUEST_ORIGIN)
CORS_ORIGIN=http://localhost:5173

# Cookie sameSite: 'lax' (default, same-site), 'none' (cross-domain, requires HTTPS)
COOKIE_SAME_SITE=lax

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:4000/api/auth/apple/callback
