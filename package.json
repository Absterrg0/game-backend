{
	"name": "game-backend",
	"version": "1.0.0",
	"description": "Game backend API with Passport OAuth, Mongoose models, and Express sessions",
	"main": "dist/server.js",
	"scripts": {
		"prestart": "yarn build",
		"start": "node dist/server.js",
		"dev": "tsx watch src/server.ts",
		"build": "tsc -p tsconfig.build.json && node scripts/write-commit-sha.mjs",
		"lint": "eslint .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "jest --config jest.all.config.ts --coverage",
		"test:watch": "jest --config jest.unit.config.ts --watch",
		"test:watch:unit": "jest --config jest.unit.config.ts --watch",
		"test:watch:integration": "jest --config jest.integration.config.ts --watch",
		"test:coverage": "yarn test",
		"test:all": "jest --config jest.all.config.ts --coverage",
		"test:unit": "jest --config jest.unit.config.ts --coverage",
		"test:integration": "jest --config jest.integration.config.ts --coverage"
	},
	"repository": {
		"type": "git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.3",
		"mongodb": "^7.1.0",
		"mongoose": "^9.2.1",
		"passport": "^0.7.0",
		"passport-apple": "^2.0.2",
		"passport-google-oauth": "^2.0.0",
		"qrcode": "^1.5.4",
		"tz-lookup": "^6.1.25",
		"winston": "^3.19.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^20.0.0",
		"@types/passport": "^1.0.17",
		"@types/qrcode": "^1",
		"@types/tz-lookup": "^6.1.2",
		"eslint": "^10.4.1",
		"globals": "^17.6.0",
		"jest": "^30.2.0",
		"mongodb-memory-server": "^11.2.0",
		"ts-jest": "^29.4.6",
		"tsx": "^4.19.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.61.0"
	},
	"packageManager": "yarn@1.22.22"
}
