{
  "name": "game-backend",
  "version": "1.0.0",
  "description": "Game backend API with Better Auth, Mongoose models, and Express",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "prestart": "yarn build",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "migrate:better-auth": "tsx scripts/migrate-better-auth.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Absterrg0/game-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Absterrg0/game-backend/issues"
  },
  "homepage": "https://github.com/Absterrg0/game-backend#readme",
  "dependencies": {
    "better-auth": "^1.5.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@1.22.22"
}
